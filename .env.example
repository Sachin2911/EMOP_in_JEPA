# Local / Vast secrets (never commit real values).
# On Vast, prefer Account Settings → Environment Variables with the same names.

WANDB_API_KEY=
GITHUB_TOKEN=
HF_TOKEN=

# Optional: used by setup scripts for git commits on remote machines
GIT_AUTHOR_NAME=
GIT_AUTHOR_EMAIL=

# Optional: override default public clone URL in vast_onstart.sh
# REPO_URL=https://github.com/YOUR_USER/EMOP_in_JEPA.git
